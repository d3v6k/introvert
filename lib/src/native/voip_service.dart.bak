import 'dart:io';
import 'package:flutter/foundation.dart';
import 'package:flutter_callkit_incoming/flutter_callkit_incoming.dart';
import 'package:flutter_callkit_incoming/entities/call_event.dart';
import 'package:flutter_callkit_incoming/entities/call_kit_params.dart';
import 'package:flutter_callkit_incoming/entities/android_params.dart';
import 'package:flutter_callkit_incoming/entities/ios_params.dart';
import 'package:uuid/uuid.dart';
import '../repository/sync_repository.dart';

/// Production-ready VoIP Background Daemon & State Orchestrator.
class VoIPService {
  static final VoIPService _instance = VoIPService._internal();
  factory VoIPService() => _instance;
  VoIPService._internal();

  final SyncRepository _repository = SyncRepository();
  bool _isInitialized = false;

  Future<void> initialize() async {
    if (_isInitialized) return;
    
    // Only initialize CallKit events on supported mobile platforms
    if (Platform.isAndroid || Platform.isIOS) {
      _listenToCallEvents();
    } else {
      debugPrint('VoIPService: CallKit not supported on ${Platform.operatingSystem}. Skipping registration.');
    }
    
    _isInitialized = true;
    debugPrint('VoIPService: Initialized.');
  }

  void _listenToCallEvents() {
    FlutterCallkitIncoming.onEvent.listen((event) async {
      if (event == null) return;
      
      switch (event.event) {
        case Event.actionCallIncoming:
          debugPrint('VoIPService: Incoming call signaling received. Waking Rust FFI...');
          await _wakeRustFFI();
          break;
        case Event.actionCallAccept:
          debugPrint('VoIPService: Call accepted.');
          break;
        case Event.actionCallDecline:
          debugPrint('VoIPService: Call declined.');
          break;
        case Event.actionCallEnded:
          debugPrint('VoIPService: Call ended.');
          break;
        case Event.actionCallTimeout:
          debugPrint('VoIPService: Call timeout.');
          break;
        default:
          break;
      }
    });
  }

  Future<void> _wakeRustFFI() async {
    final dbPath = Platform.isAndroid 
        ? "/data/data/com.example.introvert_tests/files/introvert_core"
        : "./introvert_core";
    
    final dummyKey = Uint8List(32)..fillRange(0, 32, 0x42); 
    
    final success = await _repository.initializeLocalNode(dbPath, dummyKey);
    if (success) {
      debugPrint('VoIPService: Rust FFI local node initialized.');
    }
  }

  Future<void> showMockIncomingCall(String peerId) async {
    final params = CallKitParams(
      id: Uuid().v4(),
      nameCaller: 'Secure Peer: ${peerId.substring(0, 8)}',
      appName: 'Introvert',
      avatar: 'https://i.pravatar.cc/100',
      handle: peerId,
      type: 0, // 0: Audio
      duration: 30000,
      textAccept: 'Accept',
      textDecline: 'Decline',
      extra: <String, dynamic>{'userId': peerId},
      android: AndroidParams(
        isCustomNotification: true,
        isShowLogo: false,
        ringtonePath: 'system_ringtone_default',
        backgroundColor: '#0A0E17',
        backgroundUrl: 'https://i.pravatar.cc/500',
        actionColor: '#00FFFF',
      ),
      ios: IOSParams(
        iconName: 'AppIcon',
        handleType: 'generic',
        supportsVideo: true,
        maximumCallGroups: 2,
        maximumCallsPerCallGroup: 1,
        audioSessionMode: 'default',
        audioSessionActive: true,
        supportsDTMF: true,
        supportsHolding: true,
      ),
    );

    await FlutterCallkitIncoming.showCallkitIncoming(params);
  }
}

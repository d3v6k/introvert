use libp2p::{Multiaddr, PeerId};

/// Returns a static list of global Root Bootstrap Nodes (RBNs).
/// These nodes provide initial entry points into the Sovereign P2P network.
pub fn get_bootstrap_nodes() -> Vec<(PeerId, Multiaddr)> {
    let nodes = [
        // Introvert Global Root Bootstrap Node (RBN) - Port 443 (HTTPS Bypass)
        ("12D3KooWJqiNgP67shH4m1usQtMPQyCqwCWQrnHx6bgmkGNmhz8a", "/ip4/47.89.252.80/tcp/443"),
        ("12D3KooWJqiNgP67shH4m1usQtMPQyCqwCWQrnHx6bgmkGNmhz8a", "/ip4/47.89.252.80/udp/443/quic-v1"),
        
        // Official libp2p bootstrap nodes (IP Fallbacks on Port 443/4001)
        ("QmNnooDu7bfjPFoTZYxMNLWUQJyrVwtbZg5gBMjTezGAJN", "/ip4/147.75.109.29/tcp/443"),
        ("QmNnooDu7bfjPFoTZYxMNLWUQJyrVwtbZg5gBMjTezGAJN", "/ip4/147.75.109.29/udp/443/quic-v1"),
        
        ("QmQCU2EcMqAqQPR2i9bChDtGNJchTbq5TbXJJ16u19uLTa", "/ip4/147.75.77.187/tcp/443"),
        ("QmQCU2EcMqAqQPR2i9bChDtGNJchTbq5TbXJJ16u19uLTa", "/ip4/147.75.77.187/udp/443/quic-v1"),
        
        ("QmbLHAnMoJPWSCR5Zhtx6BHJX9KiKNN6tpvbUcqanj75Nb", "/ip4/147.75.109.117/tcp/443"),
        ("QmbLHAnMoJPWSCR5Zhtx6BHJX9KiKNN6tpvbUcqanj75Nb", "/ip4/147.75.109.117/udp/443/quic-v1"),
        
        ("QmcZf59bWwK5XFi76CZX8cbJ4BhTzzA3gU1ZjYZcYW3dwt", "/ip4/147.75.109.123/tcp/443"),
        ("QmcZf59bWwK5XFi76CZX8cbJ4BhTzzA3gU1ZjYZcYW3dwt", "/ip4/147.75.109.123/udp/443/quic-v1"),
    ];

    nodes.iter().filter_map(|(pid_str, addr_str)| {
        let pid = pid_str.parse::<PeerId>().ok()?;
        let addr = addr_str.parse::<Multiaddr>().ok()?;
        Some((pid, addr))
    }).collect()
}
